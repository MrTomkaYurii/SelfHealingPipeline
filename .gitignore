# =============================================================================
# PYTHON
# =============================================================================
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# =============================================================================
# AIRFLOW — база даних та стан
# =============================================================================
airflow-pipeline/airflow.db
airflow-pipeline/airflow.db-shm
airflow-pipeline/airflow.db-wal

# Згенерований файл паролів (містить credentials)
airflow-pipeline/simple_auth_manager_passwords.json.generated

# =============================================================================
# AIRFLOW — логи (генеруються автоматично, не несуть цінності в репо)
# =============================================================================
airflow-pipeline/logs/

# =============================================================================
# ДАНІ — великі файли, які не треба тримати в репо
# =============================================================================

# DuckDB база даних
airflow-pipeline/dags/*.duckdb
airflow-pipeline/dags/*.duckdb-shm
airflow-pipeline/dags/*.duckdb-wal

# Вхідні датасети (наприклад, Yelp Academic Dataset)
airflow-pipeline/dags/*_dataset_*.json

# Проміжні та фінальні результати обробки DAG-ів
airflow-pipeline/dags/*-result.json
airflow-pipeline/dags/business-analysis_*.json
airflow-pipeline/dags/sentiment_analysis_*.json

# Папки з вхідними / вихідними даними
airflow-pipeline/input/
airflow-pipeline/output/

# =============================================================================
# BLAZOR / .NET
# =============================================================================
**/bin/
**/obj/
*.user
.vs/

# =============================================================================
# CLAUDE CODE
# =============================================================================
.claude/worktrees/

# =============================================================================
# IDE / OS
# =============================================================================
.idea/
.vscode/
.DS_Store
Thumbs.db

# =============================================================================
# WINDOWS
# =============================================================================
desktop.ini
Desktop.ini

# =============================================================================
# GOOGLE DRIVE
# =============================================================================
*.tmp.driveupload
*.tmp.drivedownload

# =============================================================================
# ЛОГИ
# =============================================================================
*.log
