    // ── SVG: Heatmap 7×24 ───────────────────────────────────────────────────

    private MarkupString DrawHeatmapSvg()
    {
        if (_heatmapData.Count == 0)
            return (MarkupString)"<div style='color:#9ca3af;text-align:center;padding:40px'>Немає даних</div>";

        const int ROWS = 7, COLS = 24, CELL = 24, GAP = 2, LEFT = 34, TOP = 30;
        int W = LEFT + COLS * (CELL + GAP) + 10;
        int H = TOP + ROWS * (CELL + GAP) + 30;

        int[,] grid = new int[ROWS, COLS];
        foreach (var c in _heatmapData)
        {
            int row = c.DayOfWeek == 0 ? 6 : c.DayOfWeek - 1;
            if (row >= 0 && row < ROWS && c.Hour >= 0 && c.Hour < COLS)
                grid[row, c.Hour] = c.Count;
        }

        int maxCount = 0;
        for (int r = 0; r < ROWS; r++)
            for (int c = 0; c < COLS; c++)
                if (grid[r, c] > maxCount) maxCount = grid[r, c];
        if (maxCount == 0) maxCount = 1;

        string[] days = { "Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Нд" };
        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {W} {H}\" style=\"width:100%\" xmlns=\"http://www.w3.org/2000/svg\">");

        for (int h = 0; h < COLS; h += 4)
        {
            double x = LEFT + h * (CELL + GAP) + CELL / 2.0;
            sb.Append($"<text x=\"{x:F0}\" y=\"{TOP - 8}\" text-anchor=\"middle\" fill=\"#9ca3af\" font-size=\"10\">{h:00}</text>");
        }

        for (int r = 0; r < ROWS; r++)
        {
            double ly = TOP + r * (CELL + GAP) + CELL / 2.0 + 4;
            sb.Append($"<text x=\"{LEFT - 6}\" y=\"{ly:F0}\" text-anchor=\"end\" fill=\"#9ca3af\" font-size=\"11\">{days[r]}</text>");
            for (int c = 0; c < COLS; c++)
            {
                double cx = LEFT + c * (CELL + GAP);
                double cy = TOP + r * (CELL + GAP);
                int count = grid[r, c];
                double t = (double)count / maxCount;
                string fill = count == 0 ? "#1f2937"
                    : $"rgb({(int)(17 + t * 57)},{(int)(24 + t * 198)},{(int)(39 + t * 89)})";
                if (count > 0)
                    sb.Append($"<rect x=\"{cx:F0}\" y=\"{cy:F0}\" width=\"{CELL}\" height=\"{CELL}\" fill=\"{fill}\" rx=\"3\"><title>{days[r]} {c:00}:00 — {count}</title></rect>");
                else
                    sb.Append($"<rect x=\"{cx:F0}\" y=\"{cy:F0}\" width=\"{CELL}\" height=\"{CELL}\" fill=\"{fill}\" rx=\"3\"/>");
            }
        }

        int scX = LEFT, scY = H - 18;
        sb.Append($"<text x=\"{scX}\" y=\"{scY + 10}\" fill=\"#9ca3af\" font-size=\"9\">менше</text>");
        for (int i = 0; i <= 8; i++)
        {
            double t2 = i / 8.0;
            string lc = i == 0 ? "#1f2937" : $"rgb({(int)(17 + t2 * 57)},{(int)(24 + t2 * 198)},{(int)(39 + t2 * 89)})";
            sb.Append($"<rect x=\"{scX + 50 + i * 14}\" y=\"{scY + 1}\" width=\"13\" height=\"12\" fill=\"{lc}\" rx=\"2\"/>");
        }
        sb.Append($"<text x=\"{scX + 50 + 9 * 14}\" y=\"{scY + 10}\" fill=\"#9ca3af\" font-size=\"9\">більше</text>");

        sb.Append("</svg>");
        return (MarkupString)sb.ToString();
    }

    // ── SVG: Rating trend line (with reference) ──────────────────────────────

    private MarkupString DrawRatingTrendSvg()
    {
        if (_ratingTrend.Count == 0)
            return (MarkupString)"<div style='color:#9ca3af;text-align:center;padding:40px'>Немає даних</div>";

        const int W = 600, H = 290, ml = 50, mr = 50, mt = 20, mb = 50;
        int cw = W - ml - mr, ch = H - mt - mb;
        const double yMin = 1.0, yMax = 5.0;
        int n = _ratingTrend.Count;
        double avg = _ratingTrend.Average(r => r.AvgStars);

        double XFor(int i) => ml + (double)i / Math.Max(n - 1, 1) * cw;
        double YFor(double v) => mt + ch - (v - yMin) / (yMax - yMin) * ch;

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {W} {H}\" style=\"width:100%\" xmlns=\"http://www.w3.org/2000/svg\">");

        for (int v = 1; v <= 5; v++)
        {
            double yy = YFor(v);
            sb.Append($"<line x1=\"{ml}\" y1=\"{yy:F1}\" x2=\"{W - mr}\" y2=\"{yy:F1}\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"{ml - 5}\" y=\"{yy + 4:F1}\" text-anchor=\"end\" fill=\"#9ca3af\" font-size=\"10\">{v}.0</text>");
        }

        double refY = YFor(avg);
        sb.Append($"<line x1=\"{ml}\" y1=\"{refY:F1}\" x2=\"{W - mr}\" y2=\"{refY:F1}\" stroke=\"#fbbf24\" stroke-width=\"1.5\" stroke-dasharray=\"6,3\"/>");
        sb.Append($"<text x=\"{W - mr + 3}\" y=\"{refY + 4:F1}\" fill=\"#fbbf24\" font-size=\"10\">⌀{avg:F2}</text>");

        var pathParts = new System.Text.StringBuilder();
        pathParts.Append($"M {XFor(0):F1},{YFor(_ratingTrend[0].AvgStars):F1}");
        for (int i = 1; i < n; i++)
            pathParts.Append($" L {XFor(i):F1},{YFor(_ratingTrend[i].AvgStars):F1}");
        string lineD = pathParts.ToString();

        sb.Append($"<path d=\"{lineD} L {XFor(n - 1):F1},{mt + ch} L {ml},{mt + ch} Z\" fill=\"rgba(83,194,246,0.1)\"/>");
        sb.Append($"<path d=\"{lineD}\" fill=\"none\" stroke=\"#53c2f6\" stroke-width=\"2\"/>");

        for (int i = 0; i < n; i++)
        {
            double px = XFor(i), py = YFor(_ratingTrend[i].AvgStars);
            sb.Append($"<circle cx=\"{px:F1}\" cy=\"{py:F1}\" r=\"3\" fill=\"#53c2f6\"/>");
            if (i % 12 == 0)
            {
                string lbl = _ratingTrend[i].Month.Length >= 4 ? _ratingTrend[i].Month[..4] : _ratingTrend[i].Month;
                sb.Append($"<text x=\"{px:F1}\" y=\"{H - mb + 18}\" text-anchor=\"middle\" fill=\"#9ca3af\" font-size=\"10\">{lbl}</text>");
            }
        }

        sb.Append("</svg>");
        return (MarkupString)sb.ToString();
    }

    // ── SVG: Top reviewers horizontal bar ────────────────────────────────────

    private MarkupString DrawTopReviewersSvg()
    {
