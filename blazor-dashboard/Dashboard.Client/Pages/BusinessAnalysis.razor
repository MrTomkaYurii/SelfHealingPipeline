    {
        _analyticsLoaded      = false;
        _analyticsLoading     = false;
        _analyticsError       = null;
        _summary              = null;
        _monthlyTrend         = [];
        _heatmapData          = [];
        _ratingTrend          = [];
        _topReviewers         = [];
        _userScatter          = [];
        _usefulness           = null;
        _lengthDist           = [];
        _fromDagRun           = false;
        _analyticsBusinessId  = "";
        _availableResultFiles = [];
        _selectedResultFileDto = null;
    }

    // ── SVG: Grouped bar (sentiment по зірках) ───────────────────────────────

    private MarkupString DrawGroupedBarSvg()
    {
        var data = _summary?.SentimentByStars;
        if (data == null || data.Count == 0 || data.All(d => d.Positive + d.Negative + d.Neutral == 0))
            return (MarkupString)"<div style='color:#9ca3af;text-align:center;padding:40px'>Немає даних</div>";

        const int W = 520, H = 300, ml = 50, mr = 20, mt = 30, mb = 60;
        int cw = W - ml - mr, ch = H - mt - mb;
        int maxVal = data.Max(d => Math.Max(d.Positive, Math.Max(d.Negative, d.Neutral)));
        if (maxVal == 0) maxVal = 1;

        const int groupW = 90, barW = 22, gap = 4;
        int leftPad = (groupW - (3 * barW + 2 * gap)) / 2;
        string[] colors = { "#4ade80", "#f87171", "#9ca3af" };

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {W} {H}\" style=\"width:100%\" xmlns=\"http://www.w3.org/2000/svg\">");

        for (int i = 0; i <= 5; i++)
        {
            int yy = mt + ch - i * ch / 5;
            sb.Append($"<line x1=\"{ml}\" y1=\"{yy}\" x2=\"{W - mr}\" y2=\"{yy}\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"{ml - 5}\" y=\"{yy + 4}\" text-anchor=\"end\" fill=\"#9ca3af\" font-size=\"10\">{maxVal * i / 5}</text>");
        }

        for (int g = 0; g < data.Count; g++)
        {
            var d = data[g];
            int gl = ml + g * groupW;
            int[] vals = { d.Positive, d.Negative, d.Neutral };
            for (int b = 0; b < 3; b++)
            {
                int bx = gl + leftPad + b * (barW + gap);
                double bh = (double)vals[b] * ch / maxVal;
                double by2 = mt + ch - bh;
                if (bh > 0)
                    sb.Append($"<rect x=\"{bx}\" y=\"{by2:F1}\" width=\"{barW}\" height=\"{bh:F1}\" fill=\"{colors[b]}\" rx=\"3\"/>");
            }
            sb.Append($"<text x=\"{gl + groupW / 2}\" y=\"{H - mb + 18}\" text-anchor=\"middle\" fill=\"#e5e7eb\" font-size=\"12\">{d.Stars}★</text>");
        }

        string[] lbls = { "Позитивні", "Негативні", "Нейтральні" };
        for (int i = 0; i < 3; i++)
        {
            int lx = ml + i * 155;
            sb.Append($"<rect x=\"{lx}\" y=\"{H - 18}\" width=\"12\" height=\"12\" fill=\"{colors[i]}\" rx=\"2\"/>");
            sb.Append($"<text x=\"{lx + 16}\" y=\"{H - 8}\" fill=\"#e5e7eb\" font-size=\"10\">{lbls[i]}</text>");
        }

        sb.Append("</svg>");
        return (MarkupString)sb.ToString();
    }

