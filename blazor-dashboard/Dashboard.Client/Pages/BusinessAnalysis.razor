@page "/business-analysis"
@inject HttpClient Http
@inject IJSRuntime JS
@using Dashboard.Client.Models
@implements IAsyncDisposable

<PageTitle>Аналіз бізнесу — Yelp</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">Аналіз бізнесу</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Джерело: <code>yelp.duckdb</code>
</MudText>

<MudTabs ActivePanelIndex="@_activeTab"
         ActivePanelIndexChanged="OnTabChanged"
         Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
    @* ════════════════════════════════════════════════════════════════
       TAB 1 — Вибір бізнесу
    ════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="Вибір бізнесу" Icon="@Icons.Material.Filled.Business">

        <br />
        @if (_loadError != null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
        }

        <MudGrid Spacing="3">

           @* ── Ліва колонка: список ── *@
                <MudItem xs="12" md="5">
                    <MudPaper Elevation="2" Class="pa-3"
                            Style="height:680px; display:flex; flex-direction:column; overflow:hidden;">

                        <div style="flex:0 0 auto;">
                            <MudTextField Value="_searchText"
                                        ValueChanged="@((string v) => _searchText = v)"
                                        Placeholder="Пошук по назві або місту..."
                                        Adornment="Adornment.Start"
                                        AdornmentIcon="@(_searching
                                            ? Icons.Material.Filled.HourglassEmpty
                                            : Icons.Material.Filled.Search)"
                                        Immediate="true"
                                        DebounceInterval="400"
                                        OnDebounceIntervalElapsed="SearchBusinesses"
                                        Clearable="true"
                                        Class="mb-2"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Dense" />
                        </div>

                        @if (_loadingBusinesses)
                        {
                            <div class="d-flex justify-center align-center flex-grow-1">
                                <MudProgressCircular Indeterminate="true"
                                                    Color="Color.Primary" Size="Size.Large" />
                            </div>
                        }
                        else
                        {
                            <div style="flex:1 1 0; min-height:0; display:flex; flex-direction:column; overflow:hidden;">

                                <div style="flex:0 0 auto;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                        @if (string.IsNullOrWhiteSpace(_searchText))
                                        { <span>Топ @_businesses.Count за кількістю відгуків</span> }
                                        else
                                        { <span>Знайдено: @_businesses.Count</span> }
                                        @if (_searching)
                                        {
                                            <MudProgressLinear Indeterminate="true" Color="Color.Primary"
                                                            Size="Size.Small" Class="mt-1" />
                                        }
                                    </MudText>
                                </div>

                                <div style="flex:1 1 0; min-height:0; overflow-y:auto;">
                                    @foreach (var biz in _businesses)
                                    {
                                        <div @onclick="() => SelectBusiness(biz)"
                                            style="@GetItemStyle(biz) padding:10px 12px; cursor:pointer;
                                                    border-bottom:1px solid rgba(255,255,255,0.06);
                                                    transition:background 0.15s;">
                                            <div style="font-weight:500; font-size:0.9rem; white-space:nowrap;
                                                        overflow:hidden; text-overflow:ellipsis;">
                                                @biz.Name
                                            </div>
                                            <div style="font-size:0.75rem; opacity:0.65; margin-top:2px;">
                                                @biz.City, @biz.State &nbsp;·&nbsp;
                                                ⭐ @biz.Stars.ToString("F1") &nbsp;·&nbsp;
                                                @biz.ReviewCount відгуків
                                            </div>
                                        </div>
                                    }
                                    @if (_businesses.Count == 100)
                                    {
                                        <div class="pa-2 text-center">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Показано перші 100 — введіть назву для уточнення
                                            </MudText>
                                        </div>
                                    }
                                </div>

                            </div>
                        }

                    </MudPaper>
                </MudItem>

            @* ── Права колонка: деталі ── *@
                <MudItem xs="12" md="7">
                    @if (_selected == null)
                    {
                        <MudPaper Elevation="2" Class="pa-6 d-flex align-center justify-center"
                                Style="height:680px;">
                            <div class="text-center" style="opacity:0.4;">
                                <MudIcon Icon="@Icons.Material.Filled.TouchApp"
                                        Style="font-size:4rem;" Class="mb-3" />
                                <MudText Typo="Typo.h6">Оберіть бізнес зі списку</MudText>
                            </div>
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Elevation="2" Class="pa-4"
                                Style="height:680px; overflow-y:auto;">

                            <MudText Typo="Typo.h5" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
                                @_selected.Name
                            </MudText>
                            <MudDivider Class="mb-3" />

                            <div class="d-flex flex-column gap-2 mb-4" style="font-size:0.95rem;">
                                <div>
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn"
                                            Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                    @_selected.City, @_selected.State
                                </div>
                                <div>
                                    <MudIcon Icon="@Icons.Material.Filled.Star"
                                            Size="Size.Small" Class="mr-1" Color="Color.Warning" />
                                    <strong>@_selected.Stars.ToString("F1")</strong> / 5.0
                                    <MudRating ReadOnly="true"
                                            SelectedValue="@((int)Math.Round(_selected.Stars))"
                                            MaxValue="5" Size="Size.Small" Class="ml-2" />
                                </div>
                                <div>
                                    <MudIcon Icon="@Icons.Material.Filled.ChatBubble"
                                            Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                    <strong>@_selected.ReviewCount.ToString("N0")</strong> відгуків
                                </div>
                                @if (!string.IsNullOrWhiteSpace(_selected.Categories))
                                {
                                    <div style="display:flex; align-items:flex-start; gap:4px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Label"
                                                Size="Size.Small" Class="mr-1 mt-1"
                                                Color="Color.Secondary" />
                                        <div style="flex:1;">
                                            @foreach (var cat in _selected.Categories.Split(';',
                                                StringSplitOptions.TrimEntries |
                                                StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <MudChip T="string" Size="Size.Small"
                                                        Variant="Variant.Outlined"
                                                        Color="Color.Primary" Class="ma-1">
                                                    @cat
                                                </MudChip>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <MudDivider Class="mb-4" />

                            @* Кнопка / прогрес / результат експорту *@
                            @if (!_exporting && _exportResult == null)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                        Size="Size.Large" FullWidth="true"
                                        StartIcon="@Icons.Material.Filled.FileDownload"
                                        OnClick="ExportReviews">
                                    Витягнути відгуки та створити JSON
                                </MudButton>
                            }
                            else if (_exporting)
                            {
                                <MudPaper Elevation="0"
                                        Class="pa-4 d-flex flex-column align-center gap-3"
                                        Style="border:1px solid rgba(255,255,255,0.1); border-radius:8px;">
                                    <MudProgressCircular Indeterminate="true"
                                                        Color="Color.Primary" Size="Size.Medium" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @_exportProgress
                                    </MudText>
                                    <MudButton Variant="Variant.Text" Color="Color.Error"
                                            StartIcon="@Icons.Material.Filled.Cancel"
                                            OnClick="CancelExport">
                                        Скасувати
                                    </MudButton>
                                </MudPaper>
                            }

                            @if (_exportResult != null)
                            {
                                @if (!string.IsNullOrEmpty(_exportResult.Error))
                                {
                                    <MudAlert Severity="Severity.Warning" Class="mb-3">
                                        @_exportResult.Error
                                    </MudAlert>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Success" Class="mb-3">
                                        ✅ Файл створено успішно!
                                    </MudAlert>

                                    <MudPaper Elevation="1" Class="pa-3 mb-3"
                                            Style="background:rgba(255,255,255,0.04);
                                                    border-radius:8px; font-size:0.875rem;">
                                        <div class="mb-1">
                                            📄 <strong>Назва файлу:</strong> @_exportResult.FileName
                                        </div>
                                        <div class="mb-1" style="word-break:break-all;">
                                            📁 <strong>Шлях:</strong>
                                            <code style="font-size:0.8rem;">@_exportResult.FilePath</code>
                                        </div>
                                        <div class="mb-1">
                                            💬 <strong>Записів:</strong>
                                            @_exportResult.ReviewCount.ToString("N0") відгуків
                                        </div>
                                        <div>🕐 <strong>Створено:</strong> @_exportResult.CreatedAt</div>
                                    </MudPaper>

                                    <div class="d-flex gap-2 mb-4">
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                                StartIcon="@Icons.Material.Filled.ContentCopy"
                                                OnClick="CopyPath">
                                            Копіювати шлях
                                        </MudButton>
                                        <MudButton Variant="Variant.Text" Color="Color.Secondary"
                                                StartIcon="@Icons.Material.Filled.Refresh"
                                                OnClick="ResetExport">
                                            Повторити
                                        </MudButton>
                                    </div>

                                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                            Size="Size.Large" FullWidth="true"
                                            StartIcon="@Icons.Material.Filled.PlayArrow"
                                            OnClick="GoToTab2">
                                        🚀 Перейти до запуску DAG →
                                    </MudButton>
                                }
                            }

                        </MudPaper>
                    }
                </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ════════════════════════════════════════════════════════════════
       TAB 2 — Запуск DAG
    ════════════════════════════════════════════════════════════════ *@

    <MudTabPanel Text="Запуск DAG"
                 Icon="@Icons.Material.Filled.PlayArrow"
                 Disabled="@(!Tab2Available)">

        <br />
        @if (!Tab2Available)
        {
            <MudAlert Severity="Severity.Info">
                Спочатку оберіть бізнес та витягніть відгуки на вкладці «Вибір бізнесу».
            </MudAlert>
        }
        else
        {
            @* ── Інфо з вкладки 1 ── *@
            <MudPaper Elevation="1" Class="pa-3 mb-4"
                      Style="background:rgba(255,255,255,0.04); border-radius:8px;">
                <div style="font-size:0.9rem;" class="d-flex flex-column gap-1">
                    <div>
                        📄 <strong>Файл:</strong> @_exportResult!.FileName
                    </div>
                    <div>
                        💬 <strong>Відгуків:</strong> @_exportResult.ReviewCount.ToString("N0")
                    </div>
                </div>
            </MudPaper>

            @* ── Форма параметрів (тільки поки не запущено) ── *@
            @if (!_dagRunning && !_dagDone && !_dagFailed && !_dagTriggering)
            {
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Параметри запуску</MudText>

                    <MudTextField @bind-Value="_ollamaModel"
                                  Label="Ollama модель"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="mb-3" />

                    <MudGrid Spacing="2" Class="mb-3">
                        <MudItem xs="6">
                            <MudNumericField @bind-Value="_batchSize"
                                             Label="Batch size (0 = всі)"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Min="0"
                                             HelperText="@($"0 = всі ({_exportResult!.ReviewCount} відгуків)")" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudNumericField @bind-Value="_offset"
                                             Label="Offset"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Min="0"
                                             HelperText="Пропустити перші N відгуків" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField Value="@_exportResult.FilePath"
                                  Label="Вхідний файл (readonly)"
                                  ReadOnly="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Lock"
                                  Class="mb-4" />

                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               Size="Size.Large" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.RocketLaunch"
                               OnClick="TriggerDag">
                        🚀 Запустити DAG
                    </MudButton>
                </MudPaper>
            }

            @* ── Тригеримо (spinner) ── *@
            @if (_dagTriggering)
            {
                <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center gap-3 mb-4">
                    <MudProgressCircular Indeterminate="true" Color="Color.Success" Size="Size.Large" />
                    <MudText Color="Color.Secondary">Відправляємо DAG в Airflow...</MudText>
                </MudPaper>
            }

            @* ── Прогрес виконання ── *@
            @if (_dagRunning || _dagDone || _dagFailed || _userCancelled)
            {
                <MudPaper Elevation="2" Class="pa-4 mb-3">

                    @* Статус *@
                    <div class="d-flex align-center gap-2 mb-3">
                        <MudText Typo="Typo.subtitle1">Статус:</MudText>
                        @switch (_dagState)
                        {
                            case "queued":
                                <MudChip T="string" Color="Color.Warning"  Icon="@Icons.Material.Filled.HourglassEmpty">queued</MudChip>
                                break;
                            case "running":
                                <MudChip T="string" Color="Color.Info"    Icon="@Icons.Material.Filled.PlayCircle">running</MudChip>
                                break;
                            case "success":
                                <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">success</MudChip>
                                break;
                            case "failed":
                                <MudChip T="string" Color="Color.Error"   Icon="@Icons.Material.Filled.Cancel">failed</MudChip>
                                break;
                            default:
                                <MudChip T="string" Color="Color.Default">@_dagState</MudChip>
                                break;
                        }
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Run ID: @_dagRunId
                        </MudText>
                    </div>

                    @* Прогрес бар *@
                    @{
                        int pct = _progTotal > 0 ? (int)(_progCurrent * 100.0 / _progTotal) : 0;
                        int remaining = _progTotal > _progCurrent ? _progTotal - _progCurrent : 0;
                        int estMinutes = (int)(remaining * 5.0 / 60);
                    }
                    <div class="d-flex justify-space-between mb-1">
                        <MudText Typo="Typo.body2">Прогрес аналізу</MudText>
                        <MudText Typo="Typo.body2">@pct%</MudText>
                    </div>
                    <MudProgressLinear Value="@pct"
                                       Color="@(_dagState == "success" ? Color.Success
                                               : _dagState == "failed"  ? Color.Error
                                               : Color.Primary)"
                                       Rounded="true" Size="Size.Large" Class="mb-2" />
                    <div class="d-flex justify-space-between mb-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Оброблено @_progCurrent з @_progTotal відгуків
                        </MudText>
                        @if (_dagState == "running" && estMinutes > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                ⏱ ~@estMinutes хв залишилось
                            </MudText>
                        }
                    </div>

                    @* Таймлайн тасків *@
                    @if (_taskInstances.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Кроки DAG</MudText>
                        <div class="d-flex flex-column gap-1 mb-3">
                            @foreach (var task in _taskInstances)
                            {
                                <div class="d-flex align-center gap-2" style="font-size:0.85rem;">
                                    @switch (task.State)
                                    {
                                        case "success":
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                     Color="Color.Success" Size="Size.Small" />
                                            break;
                                        case "running":
                                            <MudProgressCircular Indeterminate="true"
                                                                 Color="Color.Primary" Size="Size.Small" />
                                            break;
                                        case "failed":
                                            <MudIcon Icon="@Icons.Material.Filled.Error"
                                                     Color="Color.Error" Size="Size.Small" />
                                            break;
                                        default:
                                            <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty"
                                                     Color="Color.Default" Size="Size.Small" />
                                            break;
                                    }
                                    <span style="opacity:@(task.State == "none" ? "0.4" : "1")">
                                        @task.TaskId
                                    </span>
                                    @if (task.State != "none" && task.State != "queued")
                                    {
                                        <MudText Typo="Typo.caption"
                                                 Color="@(task.State == "success" ? Color.Success
                                                         : task.State == "failed" ? Color.Error
                                                         : Color.Primary)">
                                            (@task.State)
                                        </MudText>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @* Лог *@
                    @if (_logLines.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-1">
                            Лог <code>analyze_sentiment</code>
                        </MudText>
                        <div @ref="_logBox"
                             style="height:200px; overflow-y:auto; font-family:monospace;
                                    font-size:0.75rem; background:#111827; color:#d1fae5;
                                    padding:10px; border-radius:6px; white-space:pre-wrap;">
                            @foreach (var line in _logLines)
                            {
                                <div>@line</div>
                            }
                        </div>
                    }

                    @* Кнопка Скасувати *@
                    @if (_dagRunning)
                    {
                        <div class="d-flex justify-end mt-3">
                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Stop"
                                       OnClick="CancelDag">
                                ⛔ Скасувати
                            </MudButton>
                        </div>
                    }
                </MudPaper>

                @* ── Скасовано ── *@
                @if (_userCancelled)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-3">
                        ⛔ DAG скасовано користувачем
                    </MudAlert>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ResetDag">
                        Запустити знову
                    </MudButton>
                }

                @* ── Успіх ── *@
                @if (_dagDone && !_userCancelled)
                {
                    <MudAlert Severity="Severity.Success" Class="mb-3">
                        ✅ DAG завершено успішно!
                    </MudAlert>

                    @if (_outputFile != null && string.IsNullOrEmpty(_outputFile.Error))
                    {
                        <MudPaper Elevation="1" Class="pa-3 mb-3"
                                  Style="background:rgba(255,255,255,0.04); border-radius:8px;
                                         font-size:0.875rem;">
                            <div class="mb-1">
                                📄 <strong>Файл результату:</strong> @_outputFile.FileName
                            </div>
                            <div class="mb-1" style="word-break:break-all;">
                                📁 <strong>Повний шлях:</strong>
                                <code style="font-size:0.8rem;">@_outputFile.FilePath</code>
                            </div>
                            @if (_dagDuration != null)
                            {
                                <div>⏱️ <strong>Час виконання:</strong> @_dagDuration</div>
                            }
                        </MudPaper>

                        <div class="d-flex gap-2 mb-3">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.ContentCopy"
                                       OnClick="CopyOutputPath">
                                Копіювати шлях
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.BarChart"
                                       OnClick="GoToTab3">
                                Перейти до аналітики бізнесу →
                            </MudButton>
                        </div>
                    }
                    else if (_outputFile?.Error is { } err)
                    {
                        <MudAlert Severity="Severity.Info" Class="mb-3">@err</MudAlert>
                    }

                    <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="ResetDag">
                        Запустити знову
                    </MudButton>
                }

                @* ── Помилка ── *@
                @if (_dagFailed && !_userCancelled)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">
                        ❌ DAG завершився з помилкою
                    </MudAlert>
                    @if (_logLines.Count > 0)
                    {
                        <MudPaper Elevation="1" Class="pa-2 mb-3"
                                  Style="background:#1f1212; border-radius:6px; font-family:monospace;
                                         font-size:0.75rem; color:#fca5a5; max-height:150px;
                                         overflow-y:auto;">
                            @foreach (var line in _logLines.Where(l => l.Contains("ERROR") || l.Contains("Error")))
                            {
                                <div>@line</div>
                            }
                        </MudPaper>
                    }
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ResetDag">
                        Спробувати знову
                    </MudButton>
                }
            }
        }
    </MudTabPanel>

    @* ════════════════════════════════════════════════════════════════
       TAB 3 — Аналітика
    ════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="Аналітика" Icon="@Icons.Material.Filled.BarChart">

        <br />

        @* ── Блок вибору файлу результату ── *@
        <MudPaper Elevation="1" Class="pa-3 mb-4"
                  Style="background:rgba(255,255,255,0.04); border-radius:8px;">
            @if (_fromDagRun && _outputFile != null)
            {
                <div class="d-flex align-center gap-2 flex-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                             Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.body2">
                        <strong>Файл результату:</strong> @_outputFile.FileName
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                             Style="word-break:break-all; opacity:0.65;">
                        @_outputFile.FilePath
                    </MudText>
                </div>
            }
            else
            {
                <div class="d-flex align-center gap-3">
                    <MudSelect T="ResultFileDto"
                               Label="Оберіть файл результату"
                               Value="_selectedResultFileDto"
                               ValueChanged="OnResultFileSelected"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               ToStringFunc="@(f => f?.FileName ?? "")"
                               Style="flex:1; max-width:600px;">
                        @foreach (var f in _availableResultFiles)
                        {
                            <MudSelectItem T="ResultFileDto" Value="f">@f.FileName</MudSelectItem>
                        }
                    </MudSelect>
                </div>
                @if (_availableResultFiles.Count == 0 && !_analyticsLoading)
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-2">
