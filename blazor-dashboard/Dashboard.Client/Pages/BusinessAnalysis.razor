</MudTabs>

@code {
    // ── навігація ────────────────────────────────────────────────────────────
    private int  _activeTab = 0;
    private bool Tab2Available =>
        _exportResult != null && string.IsNullOrEmpty(_exportResult.Error);

    private void GoToTab2() => _activeTab = 1;

    private async Task GoToTab3()
    {
        _fromDagRun          = true;
        _analyticsBusinessId = _selected!.BusinessId;
        _analyticsLoaded     = false;
        _activeTab           = 2;
        StateHasChanged();
        await LoadAnalyticsAsync();
    }

    // ── Tab 1: бізнеси ───────────────────────────────────────────────────────
    private List<BusinessDto> _businesses        = [];
    private bool              _loadingBusinesses = true;
    private bool              _searching         = false;
    private string?           _loadError;
    private string            _searchText        = "";
    private BusinessDto?      _selected;

    // ── Tab 1: експорт ───────────────────────────────────────────────────────
    private bool              _exporting      = false;
    private string            _exportProgress = "";
    private ExportResultDto?  _exportResult;
    private CancellationTokenSource? _exportCts;

    // ── Tab 2: DAG ───────────────────────────────────────────────────────────
    private string  _ollamaModel   = "llama3.2";
    private int     _batchSize     = 0;
    private int     _offset        = 0;
    private bool    _dagTriggering = false;
    private bool    _dagRunning    = false;
    private bool    _dagDone       = false;
    private bool    _dagFailed     = false;
    private bool    _userCancelled = false;
    private string  _dagState      = "";
    private string? _dagRunId;
    private DateTime _dagStartTime;

    private int     _progCurrent = 0;
    private int     _progTotal   = 0;

    private List<TaskInstanceDto> _taskInstances = [];
    private List<string>          _logLines      = [];
    private OutputFileDto?        _outputFile;
    private string?               _dagDuration;

    private CancellationTokenSource? _pollCts;
    private ElementReference         _logBox;

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync() =>
        await LoadBusinesses(search: null, initial: true);

    public async ValueTask DisposeAsync()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        await Task.CompletedTask;
    }

    // ── Tab 1: завантаження / пошук ──────────────────────────────────────────

    private async Task LoadBusinesses(string? search, bool initial = false)
    {
        if (initial) _loadingBusinesses = true;
        else         _searching         = true;
        try
        {
            var url = string.IsNullOrWhiteSpace(search)
                ? "api/business-analysis/businesses?limit=100"
                : $"api/business-analysis/businesses?search={Uri.EscapeDataString(search)}&limit=100";
            _businesses = await Http.GetFromJsonAsync<List<BusinessDto>>(url) ?? [];
            _loadError  = null;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _loadError = "DuckDB файл не знайдено. Спочатку виконайте імпорт на вкладці «Імпорт Yelp DB».";
        }
        catch (Exception ex) { _loadError = $"Помилка завантаження: {ex.Message}"; }
        finally { _loadingBusinesses = false; _searching = false; }
    }

    private async void SearchBusinesses() => await LoadBusinesses(_searchText);

    private void SelectBusiness(BusinessDto biz)
    {
        if (_selected?.BusinessId == biz.BusinessId) return;
        _selected = biz;
        _exportResult = null;
        _exporting    = false;
        _exportCts?.Cancel();
        ResetDag();
        ResetAnalytics();
    }

    private string GetItemStyle(BusinessDto biz) =>
        _selected?.BusinessId == biz.BusinessId
            ? "background:rgba(83,194,246,0.15); border-left:3px solid var(--mud-palette-primary);"
            : "background:transparent; border-left:3px solid transparent;";

    // ── Tab 1: експорт ───────────────────────────────────────────────────────

    private async Task ExportReviews()
    {
        if (_selected == null) return;
        _exporting      = true;
        _exportResult   = null;
        _exportProgress = $"Зчитую відгуки для «{_selected.Name}»...";
        _exportCts      = new CancellationTokenSource();
        StateHasChanged();
        try
        {
            var resp = await Http.PostAsync(
                $"api/business-analysis/export/{Uri.EscapeDataString(_selected.BusinessId)}",
                null, _exportCts.Token);
            _exportProgress = "Записую NDJSON файл...";
            StateHasChanged();
            _exportResult = resp.IsSuccessStatusCode
                ? await resp.Content.ReadFromJsonAsync<ExportResultDto>()
                : new ExportResultDto { Error = await resp.Content.ReadAsStringAsync() };
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _exportResult = new ExportResultDto { Error = ex.Message }; }
        finally { _exporting = false; StateHasChanged(); }
    }

    private void CancelExport() { _exportCts?.Cancel(); _exporting = false; }

    private void ResetExport()
    {
        _exportResult = null;
        _exporting    = false;
        ResetDag();
    }

    private async Task CopyPath()
    {
        if (_exportResult?.FilePath is { } p)
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", p);
    }

    // ── Tab 2: тригер DAG ────────────────────────────────────────────────────

    private async Task TriggerDag()
    {
        if (_exportResult?.FilePath == null) return;

        _dagTriggering = true;
        _dagRunning    = false;
        _dagDone       = false;
        _dagFailed     = false;
        _userCancelled = false;
        _dagRunId      = null;
        _dagState      = "";
        _progCurrent   = 0;
        _progTotal     = _exportResult.ReviewCount;
        _taskInstances = [];
        _logLines      = [];
        _outputFile    = null;
        _dagDuration   = null;
        StateHasChanged();

        try
        {
            var resp = await Http.PostAsJsonAsync("api/airflow/trigger-dag", new
            {
                filePath    = _exportResult.FilePath,
                ollamaModel = _ollamaModel,
                lineCount   = _exportResult.ReviewCount,
                batchSize   = _batchSize,
                offset      = _offset
            });

            var result = await resp.Content.ReadFromJsonAsync<TriggerDagResultDto>();

            if (!resp.IsSuccessStatusCode || !string.IsNullOrEmpty(result?.Error))
            {
                _dagFailed = true;
                _logLines  = [$"Помилка запуску: {result?.Error ?? await resp.Content.ReadAsStringAsync()}"];
                return;
            }

            _dagRunId    = result!.RunId;
            _dagStartTime = DateTime.TryParse(result.StartTime, out var dt) ? dt : DateTime.UtcNow;
            _dagRunning  = true;
            _dagState    = "queued";
        }
        catch (Exception ex)
        {
            _dagFailed = true;
            _logLines  = [$"Виключення: {ex.Message}"];
        }
        finally
        {
            _dagTriggering = false;
            StateHasChanged();
        }

        if (_dagRunning)
            _ = StartPollingAsync();
    }

    private async Task StartPollingAsync()
    {
        _pollCts?.Cancel();
        _pollCts = new CancellationTokenSource();
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        try
        {
            while (await timer.WaitForNextTickAsync(_pollCts.Token))
            {
                await PollOnceAsync(_pollCts.Token);
                await InvokeAsync(StateHasChanged);

                if (_dagDone || _dagFailed || _userCancelled) break;
            }
        }
        catch (OperationCanceledException) { }
        finally { timer.Dispose(); }
    }

    private async Task PollOnceAsync(CancellationToken ct)
    {
        if (_dagRunId == null) return;
        try
        {
            // ── статус DAG ──
            var runResp = await Http.GetFromJsonAsync<DagRunDto>(
                $"api/airflow/dag-run/{Uri.EscapeDataString(_dagRunId)}", ct);

            if (runResp != null)
            {
                _dagState = runResp.State;

                if (runResp.State == "success")
                {
                    _dagRunning = false;
                    _dagDone    = true;
                    if (DateTime.TryParse(runResp.StartDate, out var s) &&
                        DateTime.TryParse(runResp.EndDate,   out var e))
                        _dagDuration = (e - s).ToString(@"hh\:mm\:ss");

                    _outputFile = await Http.GetFromJsonAsync<OutputFileDto>(
                        $"api/airflow/output-file/{Uri.EscapeDataString(_selected!.BusinessId)}", ct);
                }
                else if (runResp.State == "failed")
                {
                    _dagRunning = false;
                    _dagFailed  = true;
                }
            }

            // ── таски ──
            var tasks = await Http.GetFromJsonAsync<List<TaskInstanceDto>>(
                $"api/airflow/task-instances/{Uri.EscapeDataString(_dagRunId)}", ct);
            if (tasks != null) _taskInstances = tasks;

            // ── логи analyze_sentiment ──
            var logs = await Http.GetFromJsonAsync<TaskLogsDto>(
                $"api/airflow/task-logs/{Uri.EscapeDataString(_dagRunId)}/analyze_sentiment", ct);
            if (logs != null && !string.IsNullOrEmpty(logs.Error) == false)
            {
                if (logs.Total > 0)
                {
                    _progCurrent = logs.Current;
                    _progTotal   = logs.Total;
                }
                if (logs.LastLines.Count > 0) _logLines = logs.LastLines;
            }
        }
        catch (OperationCanceledException) { throw; }
        catch { /* ігноруємо тимчасові помилки мережі */ }
    }

    private async Task CancelDag()
    {
        if (_dagRunId == null) return;
        _pollCts?.Cancel();
        try
        {
            await Http.PostAsync($"api/airflow/cancel/{Uri.EscapeDataString(_dagRunId)}", null);
        }
        catch { }
        _dagRunning    = false;
        _userCancelled = true;
        _dagState      = "failed";
        StateHasChanged();
    }

    private void ResetDag()
    {
        _pollCts?.Cancel();
        _dagTriggering = false;
        _dagRunning    = false;
        _dagDone       = false;
        _dagFailed     = false;
        _userCancelled = false;
        _dagState      = "";
        _dagRunId      = null;
        _progCurrent   = 0;
        _progTotal     = 0;
        _taskInstances = [];
        _logLines      = [];
        _outputFile    = null;
        _dagDuration   = null;
        _batchSize     = 0;
        _offset        = 0;
        ResetAnalytics();
    }

    private async Task CopyOutputPath()
    {
        if (_outputFile?.FilePath is { } p)
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", p);
    }

