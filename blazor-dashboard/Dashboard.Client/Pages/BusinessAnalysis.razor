    // ── SVG: Scatter plot (user activity vs rating) ──────────────────────────

    private MarkupString DrawScatterSvg()
    {
        if (_userScatter.Count == 0)
            return (MarkupString)"<div style='color:#9ca3af;text-align:center;padding:40px'>Немає даних</div>";

        const int W = 500, H = 310, ml = 52, mr = 24, mt = 30, mb = 52;
        int cw = W - ml - mr, ch = H - mt - mb;
        int maxX = Math.Max(_userScatter.Max(p => p.TotalReviews), 1);
        const double yMin = 1.0, yMax = 5.0;

        double XFor(double v) => ml + v / maxX * cw;
        double YFor(double v) => mt + ch - (Math.Clamp(v, yMin, yMax) - yMin) / (yMax - yMin) * ch;

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {W} {H}\" style=\"width:100%\" xmlns=\"http://www.w3.org/2000/svg\">");

        // Y axis: grid lines + star labels
        for (int v = 1; v <= 5; v++)
        {
            double yy = YFor(v);
            sb.Append($"<line x1=\"{ml}\" y1=\"{yy:F1}\" x2=\"{W - mr}\" y2=\"{yy:F1}\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"{ml - 6}\" y=\"{yy + 4:F1}\" text-anchor=\"end\" fill=\"#9ca3af\" font-size=\"10\">{v}★</text>");
        }

        // X axis: tick marks + numeric labels (5 steps)
        int xTicks = Math.Min(5, maxX);
        for (int i = 0; i <= xTicks; i++)
        {
            double xVal = (double)i / xTicks * maxX;
            double xx = XFor(xVal);
            sb.Append($"<line x1=\"{xx:F1}\" y1=\"{mt + ch}\" x2=\"{xx:F1}\" y2=\"{mt + ch + 5}\" stroke=\"#6b7280\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"{xx:F1}\" y=\"{mt + ch + 17}\" text-anchor=\"middle\" fill=\"#9ca3af\" font-size=\"9\">{(int)Math.Round(xVal)}</text>");
        }

        // Axis titles
        sb.Append($"<text x=\"{ml + cw / 2}\" y=\"{H - 6}\" text-anchor=\"middle\" fill=\"#9ca3af\" font-size=\"10\">Кількість відгуків від цього користувача</text>");
        sb.Append($"<text x=\"12\" y=\"{mt + ch / 2}\" text-anchor=\"middle\" fill=\"#9ca3af\" font-size=\"10\" transform=\"rotate(-90,12,{mt + ch / 2})\">Середній рейтинг</text>");

        // Data points
        foreach (var p in _userScatter)
        {
            double px = XFor(p.TotalReviews), py = YFor(p.AvgRating);
            string color = p.AvgRating > 3.5 ? "#4ade80" : p.AvgRating < 2.5 ? "#f87171" : "#9ca3af";
            sb.Append($"<circle cx=\"{px:F1}\" cy=\"{py:F1}\" r=\"3\" fill=\"{color}\" opacity=\"0.65\"/>");
        }

        // Legend (top-left inside chart area)
        sb.Append($"<circle cx=\"{ml + 5}\" cy=\"{mt + 8}\" r=\"4\" fill=\"#4ade80\" opacity=\"0.8\"/>");
        sb.Append($"<text x=\"{ml + 13}\" y=\"{mt + 12}\" fill=\"#e5e7eb\" font-size=\"9\">рейтинг &gt; 3.5</text>");
        sb.Append($"<circle cx=\"{ml + 98}\" cy=\"{mt + 8}\" r=\"4\" fill=\"#9ca3af\" opacity=\"0.8\"/>");
        sb.Append($"<text x=\"{ml + 106}\" y=\"{mt + 12}\" fill=\"#e5e7eb\" font-size=\"9\">нейтральний</text>");
        sb.Append($"<circle cx=\"{ml + 185}\" cy=\"{mt + 8}\" r=\"4\" fill=\"#f87171\" opacity=\"0.8\"/>");
        sb.Append($"<text x=\"{ml + 193}\" y=\"{mt + 12}\" fill=\"#e5e7eb\" font-size=\"9\">рейтинг &lt; 2.5</text>");

        sb.Append("</svg>");
        return (MarkupString)sb.ToString();
    }

    // ── SVG: Two-column top words ────────────────────────────────────────────

    private MarkupString DrawTopWordsSvg()
    {
        var posW = _summary?.TopPositiveWords ?? [];
        var negW = _summary?.TopNegativeWords ?? [];
        if (posW.Count == 0 && negW.Count == 0)
            return (MarkupString)"<div style='color:#9ca3af;text-align:center;padding:40px'>Немає даних</div>";

        int rows = Math.Max(posW.Count, negW.Count);
        const int barH = 22, gap = 5, labelW = 80, barAreaW = 195;
        const int panelW = labelW + barAreaW + 15, panelGap = 20, mt = 28;
        int W = panelW * 2 + panelGap, H = mt + rows * (barH + gap) + 20;
        int maxPos = posW.Count > 0 ? posW.Max(w => w.Count) : 1;
        int maxNeg = negW.Count > 0 ? negW.Max(w => w.Count) : 1;

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {W} {H}\" style=\"width:100%\" xmlns=\"http://www.w3.org/2000/svg\">");
        sb.Append($"<text x=\"{panelW / 2}\" y=\"16\" text-anchor=\"middle\" fill=\"#4ade80\" font-size=\"12\" font-weight=\"bold\">💚 Позитивні</text>");
        sb.Append($"<text x=\"{panelW + panelGap + panelW / 2}\" y=\"16\" text-anchor=\"middle\" fill=\"#f87171\" font-size=\"12\" font-weight=\"bold\">🔴 Негативні</text>");
        sb.Append($"<line x1=\"{panelW + panelGap / 2}\" y1=\"{mt}\" x2=\"{panelW + panelGap / 2}\" y2=\"{H - 10}\" stroke=\"rgba(255,255,255,0.15)\" stroke-width=\"1\"/>");

        void DrawPanel(List<WordCountDto> words, int offsetX, string color, int maxVal)
        {
            for (int i = 0; i < words.Count; i++)
            {
                int y = mt + i * (barH + gap);
                double w = (double)words[i].Count * barAreaW / maxVal;
                sb.Append($"<text x=\"{offsetX + labelW - 5}\" y=\"{y + barH / 2 + 4}\" text-anchor=\"end\" fill=\"#e5e7eb\" font-size=\"10\">{words[i].Word}</text>");
                sb.Append($"<rect x=\"{offsetX + labelW}\" y=\"{y}\" width=\"{barAreaW}\" height=\"{barH}\" fill=\"rgba(255,255,255,0.04)\" rx=\"3\"/>");
                if (w > 0) sb.Append($"<rect x=\"{offsetX + labelW}\" y=\"{y}\" width=\"{w:F1}\" height=\"{barH}\" fill=\"{color}\" rx=\"3\"/>");
                sb.Append($"<text x=\"{offsetX + labelW + w + 4:F1}\" y=\"{y + barH / 2 + 4}\" fill=\"#9ca3af\" font-size=\"9\">{words[i].Count}</text>");
            }
        }

        DrawPanel(posW, 0, "#4ade80", maxPos);
        DrawPanel(negW, panelW + panelGap, "#f87171", maxNeg);

        sb.Append("</svg>");
        return (MarkupString)sb.ToString();
    }
}
