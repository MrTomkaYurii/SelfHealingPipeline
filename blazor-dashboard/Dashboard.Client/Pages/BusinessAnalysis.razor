    // ── Tab 3: завантаження ──────────────────────────────────────────────────

    private async Task OnTabChanged(int index)
    {
        _activeTab = index;
        if (index != 2) return;

        if (_fromDagRun)
        {
            if (!_analyticsLoaded && !_analyticsLoading)
                await LoadAnalyticsAsync();
        }
        else
        {
            if (_availableResultFiles.Count == 0)
                await LoadAvailableFilesAsync();
        }
    }

    private async Task LoadAvailableFilesAsync()
    {
        try
        {
            _availableResultFiles = await Http.GetFromJsonAsync<List<ResultFileDto>>(
                "api/analytics/result-files") ?? [];

            if (_availableResultFiles.Count > 0 && _selectedResultFileDto == null)
            {
                _selectedResultFileDto = _availableResultFiles[0];
                _analyticsBusinessId   = _selectedResultFileDto.BusinessId;
                await LoadAnalyticsAsync();
            }
            else
            {
                StateHasChanged();
            }
        }
        catch { StateHasChanged(); }
    }

    private async Task OnResultFileSelected(ResultFileDto? file)
    {
        if (file == null || file.BusinessId == _analyticsBusinessId) return;
        _selectedResultFileDto = file;
        _analyticsBusinessId   = file.BusinessId;
        _analyticsLoaded       = false;
        await LoadAnalyticsAsync();
    }

    private async Task LoadAnalyticsAsync()
    {
        if (string.IsNullOrEmpty(_analyticsBusinessId)) return;
        _analyticsLoading = true;
        _analyticsError   = null;
        StateHasChanged();
        try
        {
            var bid = Uri.EscapeDataString(_analyticsBusinessId);
            var t1 = Http.GetFromJsonAsync<SentimentSummaryDto>($"api/analytics/summary/{bid}");
            var t2 = Http.GetFromJsonAsync<List<MonthlyCountDto>>($"api/analytics/monthly-trend/{bid}");
            var t3 = Http.GetFromJsonAsync<List<HeatmapCellDto>>($"api/analytics/heatmap/{bid}");
            var t4 = Http.GetFromJsonAsync<List<MonthlyRatingDto>>($"api/analytics/rating-trend/{bid}");
            var t5 = Http.GetFromJsonAsync<List<TopReviewerDto>>($"api/analytics/top-reviewers/{bid}");
            var t6 = Http.GetFromJsonAsync<List<ScatterPointDto>>($"api/analytics/user-scatter/{bid}");
            var t7 = Http.GetFromJsonAsync<UsefulnessDto>($"api/analytics/usefulness/{bid}");
            var t8 = Http.GetFromJsonAsync<List<LengthBucketDto>>($"api/analytics/length-distribution/{bid}");

            await Task.WhenAll(t1, t2, t3, t4, t5, t6, t7, t8);

            _summary         = t1.Result;
            _monthlyTrend    = t2.Result ?? [];
            _heatmapData     = t3.Result ?? [];
            _ratingTrend     = t4.Result ?? [];
            _topReviewers    = t5.Result ?? [];
            _userScatter     = t6.Result ?? [];
            _usefulness      = t7.Result;
            _lengthDist      = t8.Result ?? [];
            _analyticsLoaded = true;
        }
        catch (Exception ex) { _analyticsError = ex.Message; }
        finally { _analyticsLoading = false; StateHasChanged(); }
    }

